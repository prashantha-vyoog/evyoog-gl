{
  "name": "eVyoog GL Development",

  "image": "mcr.microsoft.com/devcontainers/universal:2",

  "forwardPorts": [8080, 5432],
  "portsAttributes": {
    "8080": {
      "label": "eVyoog GL API",
      "onAutoForward": "notify"
    },
    "5432": {
      "label": "PostgreSQL",
      "onAutoForward": "silent"
    }
  },

  "postCreateCommand": "bash .devcontainer/post-create.sh",

  "remoteEnv": {
    "SPRING_DATASOURCE_URL": "jdbc:postgresql://localhost:5432/evyoog_gl",
    "SPRING_DATASOURCE_USERNAME": "evyoog_app",
    "SPRING_DATASOURCE_PASSWORD": "evyoog_dev_pass",
    "SPRING_PROFILES_ACTIVE": "dev"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vscjava.vscode-spring-initializr",
        "vscjava.vscode-maven",
        "pivotal.vscode-spring-boot",
        "redhat.java",
        "vscjava.vscode-java-debug",
        "vscjava.vscode-java-test",
        "eamodio.gitlens",
        "humao.rest-client",
        "42crunch.vscode-openapi",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg",
        "streetsidesoftware.code-spell-checker",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "java.compile.nullAnalysis.mode": "automatic",
        "java.configuration.updateBuildConfiguration": "automatic",
        "java.server.launchMode": "Standard",
        "editor.formatOnSave": true,
        "editor.tabSize": 4,
        "editor.insertSpaces": true,
        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true,
        "java.jdt.ls.java.home": "/usr/lib/jvm/java-21-amazon-corretto",
        "sqltools.connections": [
          {
            "name": "eVyoog GL (dev)",
            "driver": "PostgreSQL",
            "server": "localhost",
            "port": 5432,
            "database": "evyoog_gl",
            "username": "evyoog_app",
            "password": "evyoog_dev_pass"
          }
        ],
        "rest-client.environmentVariables": {
          "dev": {
            "baseUrl": "http://localhost:8080",
            "contentType": "application/json"
          }
        }
      }
    }
  }
}
